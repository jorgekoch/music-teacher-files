generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int     @id @default(autoincrement())
  email     String  @unique
  password  String
  name      String  @default("Usuário")
  avatarUrl String?
  plan      String  @default("FREE")

  stripeCustomerId     String?
  stripeSubscriptionId String?
  subscriptionStatus   String?

  resetPasswordToken     String?
  resetPasswordExpiresAt DateTime?

  emailVerified              Boolean   @default(false)
  emailVerificationToken     String?
  emailVerificationExpiresAt DateTime?

  createdAt DateTime @default(now())

  folders              Folder[]
  ownedFolderShares    FolderShare[]       @relation("FolderShareOwner")
  receivedFolderShares FolderShare[]       @relation("FolderShareRecipient")
  folderShareInvites   FolderShareInvite[] @relation("FolderShareInviteOwner")
}

model Folder {
  id        Int      @id @default(autoincrement())
  name      String
  userId    Int
  createdAt DateTime @default(now())

  user         User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  files        File[]
  shares       FolderShare[]
  shareInvites FolderShareInvite[]
}

model File {
  id         Int      @id @default(autoincrement())
  name       String
  url        String?
  storageKey String
  size       Int?
  folderId   Int
  createdAt  DateTime @default(now())

  folder      Folder       @relation(fields: [folderId], references: [id], onDelete: Cascade)
  sharedFiles SharedFile[]
}

model WaitlistLead {
  id        Int      @id @default(autoincrement())
  name      String?
  email     String   @unique
  interest  String   @default("PRO")
  createdAt DateTime @default(now())
}

model SharedFile {
  id        Int       @id @default(autoincrement())
  token     String    @unique
  fileId    Int
  expiresAt DateTime?
  createdAt DateTime  @default(now())

  file File @relation(fields: [fileId], references: [id], onDelete: Cascade)
}

model FolderShare {
  id               Int      @id @default(autoincrement())
  folderId         Int
  ownerUserId      Int
  sharedWithUserId Int
  role             String   @default("viewer")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  folder         Folder @relation(fields: [folderId], references: [id], onDelete: Cascade)
  ownerUser      User   @relation("FolderShareOwner", fields: [ownerUserId], references: [id], onDelete: Cascade)
  sharedWithUser User   @relation("FolderShareRecipient", fields: [sharedWithUserId], references: [id], onDelete: Cascade)

  @@unique([folderId, sharedWithUserId])
}

model FolderShareInvite {
  id           Int       @id @default(autoincrement())
  token        String    @unique
  folderId     Int
  ownerUserId  Int
  invitedEmail String
  role         String    @default("viewer")
  acceptedAt   DateTime?
  expiresAt    DateTime?
  createdAt    DateTime  @default(now())

  folder    Folder @relation(fields: [folderId], references: [id], onDelete: Cascade)
  ownerUser User   @relation("FolderShareInviteOwner", fields: [ownerUserId], references: [id], onDelete: Cascade)
}
